TELEGRAM_BOT_TOKEN=replace_me
OPENAI_API_KEY=replace_me
RSS_FEED_URL=https://example.com/rss.xml
TIMEZONE=UTC
# Path to the SQLite DB. On Render (or any host with an ephemeral app dir) point
# this at a persistent disk mount, e.g. /var/data/data.db, so forecast history,
# users and rubric rotation survive deploys. Leave unset for local dev.
DATABASE_PATH=/var/data/data.db
OPENAI_MODEL=gpt-5.4-mini
CHANNEL_TONE=savage
BROADCAST_CHANNEL=@your_channel
ADMIN_USER_IDS=123456789
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_me
TELEGRAM_NEWS_CHANNEL=https://t.me/your_channel_or_invite
TELEGRAM_NEWS_LIMIT=20
TELETHON_SESSION=telethon.session
TELETHON_SESSION_STRING=replace_me
